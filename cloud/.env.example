# tmdx Cloud Server (Go) — Environment Variables
#
# Copy this file to .env and adjust as needed.
# For local single-user use, NO variables are required — defaults work out of the box.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=1071
HOST=0.0.0.0
NODE_ENV=development

# ---------------------------------------------------------------------------
# Database (SQLite)
# ---------------------------------------------------------------------------
# DATABASE_PATH=./data/tc.db

# ---------------------------------------------------------------------------
# Authentication (optional — leave blank for local no-auth mode)
# ---------------------------------------------------------------------------

# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:1071/auth/github/callback

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:1071/auth/google/callback

# ---------------------------------------------------------------------------
# JWT Secrets (change these in production!)
# ---------------------------------------------------------------------------
# JWT_SECRET=change-me-to-a-random-string
# AGENT_JWT_SECRET=change-me-to-a-different-random-string

# ---------------------------------------------------------------------------
# Optional — Discord webhook for notifications
# ---------------------------------------------------------------------------
# DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Optional — Hosting config (only needed for multi-domain setups)
# ---------------------------------------------------------------------------
# CLOUD_HOST=localhost:1071
# APP_HOST=
# LANDING_DIR=
